{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/send-to-g2/shared-item.schema.json",
  "title": "SharedItem",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "createdAt", "read"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["text", "url", "image", "file"]
    },
    "title": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "uri": {
      "type": "string"
    },
    "sourceApp": {
      "type": "string"
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0
    },
    "read": {
      "type": "boolean"
    },
    "origin": {
      "type": "string",
      "enum": ["share", "dynamic"]
    },
    "dynamicSourceId": {
      "type": "string",
      "minLength": 1
    },
    "dynamicFingerprint": {
      "type": "string",
      "minLength": 1
    }
  }
}
